#!/usr/bin/env bash

# Formats tmux window title based on active pane's process
# Usage: tmux-window-title <pane_current_command> <window_name>

COMMAND="$1"
WINDOW_NAME="$2"

# Claude Code shows version as command (e.g., "2.1.20")
if [[ "$COMMAND" =~ ^[0-9]+\.[0-9]+\.[0-9]+ ]]; then
  echo "🤖 Claude Code"
elif [[ "$COMMAND" == "nvim" ]]; then
  echo "$COMMAND"
else
  # For everything else, prefer window name if set, else command
  echo "${WINDOW_NAME:-$COMMAND}"
fi
