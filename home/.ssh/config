# SSH client config (managed via dotfiles / Stow)
# Keeps key passphrases persisted in macOS Keychain across reboots/idle
# sessions instead of re-prompting or requiring ssh-add every time.

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IgnoreUnknown UseKeychain

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
