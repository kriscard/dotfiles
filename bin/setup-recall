#!/usr/bin/env bash
# Bootstrap the Karpathy LLM-wiki recall stack on a fresh machine.
# Idempotent: safe to re-run. Run AFTER `dotfiles init` (needs brew, stow, asdf,
# and the symlinked ~/.claude + launchd plist already in place).
#
#   ~/.dotfiles/bin/setup-recall
#
# Sets up: asdf Node 24, qmd (npm global), the vault clone, the qmd "vault"
# collection, the first index build, the reindex launchd job, and the Skills repo.
set -euo pipefail

VAULT_DIR="${HOME}/obsidian-vault-kriscard"
VAULT_REMOTE="https://github.com/kriscard/obsidian-vault-kriscard.git"
SKILLS_DIR="${HOME}/projects/Skills"
SKILLS_REMOTE="https://github.com/kriscard/Skills.git"
PLIST_LABEL="com.kriscard.qmd-reindex"
PLIST="${HOME}/Library/LaunchAgents/${PLIST_LABEL}.plist"

# asdf shims first so node/qmd resolve to Node 24 (qmd's better-sqlite3 native
# module is built against MODULE_VERSION 137). Mirrors bin/qmd-reindex.
export PATH="${HOME}/.asdf/shims:/opt/homebrew/bin:${PATH}"

DOTFILES_DIR="$(cd -P "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

step() { echo -e "\n\033[1;34m==>\033[0m $1"; }
ok()   { echo -e "\033[1;32m  ok\033[0m $1"; }
warn() { echo -e "\033[1;33m  !!\033[0m $1"; }
die()  { echo -e "\033[1;31mError:\033[0m $1" >&2; exit 1; }

# 1. Node 24 via asdf -------------------------------------------------------
step "asdf Node 24"
command -v asdf >/dev/null || die "asdf missing. Run 'dotfiles packages' first."
asdf plugin list 2>/dev/null | grep -qx nodejs || asdf plugin add nodejs
# Installs the version pinned in ~/.tool-versions (nodejs 24.15.0).
asdf install nodejs 2>/dev/null || true
node --version | grep -q "^v24" || warn "node is $(node --version), expected v24.x (check ~/.tool-versions)"
ok "$(node --version)"

# 2. qmd (npm global, NOT brew) ---------------------------------------------
step "qmd search engine"
if command -v qmd >/dev/null; then
  ok "qmd present ($(qmd --version 2>/dev/null || echo installed))"
else
  npm install -g @tobilu/qmd
  asdf reshim nodejs 2>/dev/null || true
  command -v qmd >/dev/null || die "qmd install failed"
  ok "qmd installed"
fi

# 3. Vault clone ------------------------------------------------------------
step "vault at ${VAULT_DIR}"
if [ -d "${VAULT_DIR}/.git" ]; then
  ok "vault already cloned"
else
  git clone "${VAULT_REMOTE}" "${VAULT_DIR}"
  ok "vault cloned"
fi

# 4. qmd 'vault' collection -------------------------------------------------
step "qmd 'vault' collection"
if qmd collection list 2>/dev/null | grep -qw vault; then
  ok "collection registered"
else
  qmd collection add "${VAULT_DIR}" --name vault
  ok "collection added"
fi

# 5. First index build ------------------------------------------------------
step "initial index (update + embed)"
"${DOTFILES_DIR}/bin/qmd-reindex"
ok "index built (log: ~/.cache/qmd/reindex.log)"

# 6. Reindex launchd job ----------------------------------------------------
step "reindex schedule"
[ -e "${PLIST}" ] || die "plist not symlinked at ${PLIST}. Run 'dotfiles stow' first."
if launchctl list 2>/dev/null | grep -q "${PLIST_LABEL}"; then
  ok "launchd job loaded"
else
  launchctl bootstrap "gui/$(id -u)" "${PLIST}" 2>/dev/null \
    || launchctl load -w "${PLIST}" 2>/dev/null \
    || warn "could not load ${PLIST_LABEL}; load it manually"
  ok "launchd job loaded"
fi

# 7. Skills repo + symlinks -------------------------------------------------
step "Skills repo"
if [ -d "${SKILLS_DIR}/.git" ]; then
  ok "Skills already cloned"
else
  git clone "${SKILLS_REMOTE}" "${SKILLS_DIR}"
  ok "Skills cloned"
fi
if [ -x "${SKILLS_DIR}/scripts/link-skills.sh" ]; then
  "${SKILLS_DIR}/scripts/link-skills.sh"
  ok "skills linked into ~/.claude/skills"
else
  warn "link-skills.sh not found/executable in ${SKILLS_DIR}/scripts"
fi

# 8. Smoke test -------------------------------------------------------------
step "smoke test"
if qmd query "react" --json -n 1 2>/dev/null | grep -q '"score"'; then
  ok "recall works: qmd returns hits over the vault"
else
  warn "qmd returned no hits; check ~/.cache/qmd/reindex.log"
fi

echo -e "\n\033[1;32m✅ recall stack ready.\033[0m Open Claude Code in ${VAULT_DIR} and try: what do I know about react?"
