#!/bin/sh
# herdr-sesh: sesh-style project launcher for herdr.
# Fuzzy-pick a project via zoxide, then focus its workspace if already open
# (matched by label = dir basename), else create a new workspace there.
set -eu

dir=$(zoxide query -l | fzf --reverse --border --prompt '⚡ project > ') || exit 0
[ -n "$dir" ] || exit 0

name=$(basename "$dir")
id=$(herdr workspace list 2>/dev/null \
  | jq -r --arg n "$name" '.result.workspaces[]? | select(.label == $n) | .workspace_id' 2>/dev/null \
  | head -n1 || true)

if [ -n "${id:-}" ]; then
  herdr workspace focus "$id"
else
  herdr workspace create --cwd "$dir" --focus
fi
