#!/usr/bin/env bash
set -f

input=$(cat)

if [ -z "$input" ]; then
    printf "Claude"
    exit 0
fi

# ── Catppuccin Macchiato — true color (24-bit) ─────────
# Foreground helper: \033[38;2;R;G;Bm
# Background helper: \033[48;2;R;G;Bm
reset='\033[0m'

# Segment bg/fg pairs (dark fg on colored bg)
crust_fg='\033[38;2;24;25;38m'    # #181926

mauve_bg='\033[48;2;198;160;246m' # #c6a0f6
mauve_fg='\033[38;2;198;160;246m'

blue_bg='\033[48;2;138;173;244m'  # #8aadf4
blue_fg='\033[38;2;138;173;244m'

surface1_bg='\033[48;2;73;77;100m'  # #494d64
surface1_fg='\033[38;2;73;77;100m'

surface0_bg='\033[48;2;54;58;79m'   # #363a4f
surface0_fg='\033[38;2;54;58;79m'

# Text colors
text_fg='\033[38;2;202;211;245m'     # #cad3f5
subtext_fg='\033[38;2;165;173;203m'  # #a5adcb
overlay_fg='\033[38;2;110;115;141m'  # #6e738d
green_txt='\033[38;2;166;218;149m'
yellow_txt='\033[38;2;238;212;159m'
peach_txt='\033[38;2;245;169;127m'
red_txt='\033[38;2;237;135;150m'
teal_txt='\033[38;2;139;213;202m'

# Powerline arrow
arrow=$'\uE0B0'

# ── Helpers ─────────────────────────────────────────────
color_for_pct() {
    local pct=$1
    if [ "$pct" -ge 90 ]; then printf "$red_txt"
    elif [ "$pct" -ge 70 ]; then printf "$yellow_txt"
    elif [ "$pct" -ge 50 ]; then printf "$peach_txt"
    else printf "$green_txt"
    fi
}

# ── Extract data ────────────────────────────────────────
model_name=$(echo "$input" | jq -r '.model.display_name // "Claude"')

size=$(echo "$input" | jq -r '.context_window.context_window_size // 200000')
[ "$size" -eq 0 ] 2>/dev/null && size=200000
input_tokens=$(echo "$input" | jq -r '.context_window.current_usage.input_tokens // 0')
cache_create=$(echo "$input" | jq -r '.context_window.current_usage.cache_creation_input_tokens // 0')
cache_read=$(echo "$input" | jq -r '.context_window.current_usage.cache_read_input_tokens // 0')
current=$(( input_tokens + cache_create + cache_read ))
pct_used=$(( size > 0 ? current * 100 / size : 0 ))

cwd=$(echo "$input" | jq -r '.cwd // ""')
[ -z "$cwd" ] || [ "$cwd" = "null" ] && cwd=$(pwd)
dirname=$(basename "$cwd")

git_branch="" git_dirty=""
if git -C "$cwd" --no-optional-locks rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git_branch=$(git -C "$cwd" --no-optional-locks symbolic-ref --short HEAD 2>/dev/null)
    [ -n "$(git -C "$cwd" --no-optional-locks status --porcelain 2>/dev/null)" ] && git_dirty=" ●"
fi

session_cost=$(echo "$input" | jq -r '.cost.total_cost_usd // 0')
session_cost_fmt=$(printf '$%.2f' "$session_cost")


# Model icon (Nerd Font — using printf to preserve glyphs)
case "$model_name" in
    *[Oo]pus*)   model_icon=$(printf '\U000f0219') ;;  # 󰈙 nf-md-file_music
    *[Ss]onnet*) model_icon=$(printf '\U000f001e') ;;  # 󰀞 nf-md-music_note
    *[Hh]aiku*)  model_icon=$(printf '\U000f06d6') ;;  # 󰛖 nf-md-leaf
    *)           model_icon=$(printf '\U000f110e') ;;  # 󱄎 nf-md-brain
esac

# ── Powerline segments ────────────────────────────────
# Segment order: Model → Directory (+ git) → Context → Session
line1=""

# Segment 1: Model (mauve bg)
line1+="${mauve_bg}${crust_fg} ${model_icon} ${model_name} "

# Arrow: mauve → blue
line1+="${reset}${blue_bg}${mauve_fg}${arrow}"

# Nerd Font icons via printf
icon_folder=$(printf '\U000f024b')   # 󰉋 nf-md-folder
icon_branch=$(printf '\U000f062c')   # 󰘬 nf-md-source_branch
icon_ctx=$(printf '\U000f110e')      # 󱄎 nf-md-brain

# Segment 2: Directory + git branch (blue bg)
line1+="${blue_bg}${crust_fg} ${icon_folder} ${dirname}"
if [ -n "$git_branch" ]; then
    line1+=" ${icon_branch} ${git_branch}${git_dirty}"
fi
line1+=" "

# Arrow: blue → surface1
line1+="${reset}${surface1_bg}${blue_fg}${arrow}"

# Segment 3: Context % (surface1 bg)
pct_color=$(color_for_pct "$pct_used")
line1+="${surface1_bg}${text_fg} ${icon_ctx} ${pct_used}% "

# Segment 4: Session cost (surface0 bg)
if [ "$session_cost" != "0" ] && [ "$session_cost" != "null" ]; then
    line1+="${reset}${surface0_bg}${surface1_fg}${arrow}"
    line1+="${surface0_bg}${teal_txt} ${session_cost_fmt} "
    line1+="${reset}${surface0_fg}${arrow}${reset}"
else
    line1+="${reset}${surface1_fg}${arrow}${reset}"
fi

# ── Output ──────────────────────────────────────────────
printf "%b" "$line1"

exit 0
