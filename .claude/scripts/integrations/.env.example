# Integrations layer credentials — copy to .env and fill in
# .env is gitignored; never commit real values.

# GitHub: uses `gh` CLI auth, nothing to set here.

# Gmail / Google Calendar: OAuth — tokens cached in .tokens/google.json
# Run `python -m integrations.gmail --setup` to start the OAuth flow.

# Jira (Atlassian Cloud)
# JIRA_EMAIL=your.email@example.com
# JIRA_API_TOKEN=<generate at id.atlassian.com/manage-profile/security/api-tokens>
# JIRA_DOMAIN=your-domain  # without .atlassian.net

# Linear (when phase 4.5 ships)
# LINEAR_API_KEY=<generate at linear.app/settings/api>
