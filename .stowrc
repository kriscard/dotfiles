--target=$HOME
--no-folding
--ignore=.stowrc
--ignore=.stow-local-ignore
--ignore=DS_Store
--ignore=atuin/*

# Runtime/local files that should never be linked from the dotfiles repo
--ignore=^\.config/raycast
--ignore=^\.config/tmux/plugins/tmux-resurrect
--ignore=^\.config/ghostty/local-config/config
--ignore=^\.config/herdr/session\.json

--ignore=^\.claude/debug
--ignore=^\.claude/projects
--ignore=^\.claude/history\.jsonl
--ignore=^\.claude/todos
--ignore=^\.claude/file-history
--ignore=^\.claude/shell-snapshots
--ignore=^\.claude/statsig
--ignore=^\.claude/plans
--ignore=^\.claude/plugins
--ignore=^\.claude/stats-cache\.json
--ignore=^\.claude/eslint_errors\.json
--ignore=^\.claude/settings\.local\.json
--ignore=^\.claude/settings\.json
--ignore=^\.claude/backups
--ignore=^\.claude/cache
--ignore=^\.claude/skills
--ignore=^\.claude/local-plugins
--ignore=^\.claude/session-env
--ignore=^\.claude/sessions
--ignore=^\.claude/tasks
--ignore=^\.claude/teams
--ignore=^\.claude/telemetry
--ignore=^\.claude/\.last-cleanup
--ignore=^\.claude/\.last-update-result\.json
--ignore=^\.claude/profiles/settings-work\.json

--ignore=^\.pi/agent/auth\.json
--ignore=^\.pi/agent/trust\.json
--ignore=^\.pi/agent/sessions
--ignore=^\.pi/agent/npm
--ignore=^\.pi/agent/git
