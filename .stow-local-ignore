# Stow ignore patterns for the `home` package.
# GNU Stow matches these against relative paths inside the package.

# App/runtime files that should not be stowed
^\.config/raycast
^\.config/tmux/plugins/tmux-resurrect
^\.config/ghostty/local-config/config
^\.config/herdr/session\.json

# Claude Code runtime/cache/local files (not config)
^\.claude/debug
^\.claude/projects
^\.claude/history\.jsonl
^\.claude/todos
^\.claude/file-history
^\.claude/shell-snapshots
^\.claude/statsig
^\.claude/plans
^\.claude/plugins
^\.claude/stats-cache\.json
^\.claude/eslint_errors\.json
^\.claude/settings\.local\.json
^\.claude/backups
^\.claude/cache
^\.claude/skills
^\.claude/local-plugins
^\.claude/session-env
^\.claude/sessions
^\.claude/tasks
^\.claude/teams
^\.claude/telemetry
^\.claude/\.last-cleanup
^\.claude/\.last-update-result\.json
# Shared Agent Skills install location
^\.agents/skills

# Pi runtime files and installed package caches (config/resources are stowed)
^\.pi/agent/auth\.json
^\.pi/agent/settings\.json
^\.pi/agent/trust\.json
^\.pi/agent/sessions
^\.pi/agent/skills
^\.pi/agent/npm
^\.pi/agent/git

^node_modules
