#!/usr/bin/env bash
# Roofr: pick a PR, spin up a headless worktree via make wt-start, open in Octo.

RDEV="$HOME/Code/roofr-dev"
cd "$RDEV" || exit 1

git -C roofr fetch origin --prune

PR_NUMBER=$(gh pr list --json number,title,headRefName,baseRefName \
    --template '{{range .}}{{.number}}	[{{.baseRefName}}] {{.title}} ({{.headRefName}}){{"\n"}}{{end}}' \
    | gum filter --limit 1 --fuzzy --placeholder "Pick a PR to review" --prompt "👀 " \
    | cut -f1)

if [ -z "$PR_NUMBER" ]; then
    echo "No PR selected."
    exit 0
fi

BRANCH=$(gh pr view "$PR_NUMBER" --json headRefName --jq '.headRefName')
if [ -z "$BRANCH" ]; then
    echo "Could not resolve branch for PR #$PR_NUMBER"
    exit 1
fi

# Sanitize branch to valid slug
SLUG=$(echo "$BRANCH" | tr '[:upper:]/' '[:lower:]-' | sed 's/^[^a-z0-9]*//' | cut -c1-20)

WORKTREE_PATH="$RDEV/roofr__worktrees/$SLUG"

if [ ! -d "$WORKTREE_PATH" ]; then
    echo "Spinning up worktree for PR #$PR_NUMBER ($BRANCH → $SLUG)..."
    # Headless: skip Vite + node_modules hydration, only need code + DB for review
    make wt-start name="$SLUG" ARGS="--without frontend --base origin/$BRANCH"
else
    echo "Worktree $SLUG already exists, resuming..."
    make wt-start name="$SLUG"
fi

echo "Opening PR #$PR_NUMBER in Octo..."
tmux new-window -c "$WORKTREE_PATH/roofr" "nvim -c 'Octo pr edit $PR_NUMBER'"
