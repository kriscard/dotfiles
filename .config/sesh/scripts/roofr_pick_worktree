#!/usr/bin/env bash
# Roofr: pick an existing worktree from roofr__worktrees/ and connect via sesh.

WORKTREES_DIR="$HOME/Code/roofr-dev/roofr__worktrees"

if [ ! -d "$WORKTREES_DIR" ]; then
    echo "No worktrees found at $WORKTREES_DIR"
    exit 1
fi

SLUG=$(ls "$WORKTREES_DIR" | gum filter --limit 1 --fuzzy --no-sort \
    --placeholder "Pick a worktree" --prompt "🌲 ")

if [ -n "$SLUG" ]; then
    sesh connect "$WORKTREES_DIR/$SLUG"
fi
